{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "P3 Platform",
  "version": "0.2.5",
  "identifier": "dev.p3platform.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Reading Practice",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../passages/visiting_nyc.txt": "passages/visiting_nyc.txt",
      "../../passages/visiting_nyc.ipa.json": "passages/visiting_nyc.ipa.json",
      "resources/threshold_table_v1.json": "resources/threshold_table_v1.json",
      "resources/model_vocab_v1.json": "resources/model_vocab_v1.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
