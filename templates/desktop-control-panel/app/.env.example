# Build-time pinning for a PRODUCTION release build.
#
# These feed BuildConfig (src-tauri/src/shared/config.rs) via option_env! at
# COMPILE time. They are consumed only by the `tauri:build:release` npm script
# (`dotenv -e .env -- tauri build`). A bare `npm run tauri build` / `cargo build`
# ignores this file and falls back to the dev sentinels (example.invalid +
# zero-SHA), so dev builds stay safe-by-default.
#
# Setup:  cp .env.example .env   (then run `npm run tauri:build:release` from app/)
# .env is gitignored; .env.example (this file) is the committed template.
#
# All values below are public (the model artifact is a public GitHub release
# asset). If first-run reports a digest mismatch, IAS_MODEL_SHA256 here has
# drifted from the published asset — the clean-machine smoke is what catches it.

# ONNX model download URL (public GitHub release asset; ~339 MB, not bundled — T-DST-1).
# Hosted on Pace-IAS/pronounce (the public download page repo), NOT the app-release repo.
IAS_MODEL_URL=https://github.com/Pace-IAS/pronounce/releases/download/model-v0.1.0/ias-model-0.1.0.onnx

# Hex SHA-256 of the pinned model file. Must match the published asset.
IAS_MODEL_SHA256=e88bbad6cd890c193ba42c63f708383b8b646e0e7382db8d4392efbfe8e2edb0

# Semver-ish identifier for the pinned model.
IAS_MODEL_VERSION=0.1.0

# Updater manifest endpoint (CL-23-lite opt-in banner). App releases live on Pace-IAS/IAS.
IAS_UPDATER_MANIFEST_URL=https://github.com/Pace-IAS/IAS/releases/latest/download/latest.json

# --- Intentionally unset for the offline reviewer build ---
# IAS_BACKEND_URL    — Phase B; reports queue locally to SQLite when unset.
# IAS_UPDATER_PUBKEY — CL-23-lite uses no Ed25519; Phase C heavyweight updater only.
# IAS_APP_VERSION    — omit; defaults to Cargo.toml package version (0.2.0).
# IAS_ORT_DYLIB_PATH — runtime-only dev override; not needed, the DLL is bundled (Task 1).
